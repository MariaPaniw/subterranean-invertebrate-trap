    <!-- ============================================================ -->
    <!--  OTHER ENTITY (R analysis script)                            -->
    <!-- ============================================================ -->
    <otherEntity id="Rscript">
      <entityName>analyses_subterranean_submission.R</entityName>
      <entityDescription>
        Self-contained R script (1296 lines, last updated 2025-07-06) that
        reproduces all analyses and figures in the associated manuscript.
        Sections: (1) data loading and preparation; (2) species richness
        GLMMs; (3) richness by trap layer; (4) biomass GLMMs; (5) biomass
        by trap layer; (6) abundance multivariate MCMCglmm analyses.
        Required R packages: lubridate, mgcv, dplyr, ggplot2, viridis,
        glmmTMB, readxl, MCMCglmm, tidyr, hdrcde, coda, MCMCvis, patchwork.
        Users must set their local working directory path in the script
        before running (search for YOUR_LOCAL_PATH).
      </entityDescription>
      <physical>
        <objectName>analyses_subterranean_submission.R</objectName>
        <dataFormat>
          <externallyDefinedFormat>
            <formatName>R script</formatName>
            <formatVersion>≥ 4.0</formatVersion>
          </externallyDefinedFormat>
        </dataFormat>
        <distribution>
          <online>
            <url>https://github.com/MariaPaniw/subterranean-invertebrate-trap/blob/main/analyses_subterranean_submission.R</url>
          </online>
        </distribution>
      </physical>
      <entityType>R script</entityType>
    </otherEntity>

