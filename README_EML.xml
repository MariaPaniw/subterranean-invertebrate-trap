    <!-- ---------------------------------------------------------- -->
    <!--  1. TableS1_forAnalysis.csv                                 -->
    <!-- ---------------------------------------------------------- -->
    <dataTable id="tableS1">
      <entityName>TableS1_forAnalysis.csv</entityName>
      <entityDescription>
        Main invertebrate occurrence dataset. Each row represents one
        taxonomic record collected from a single trap on a single collection
        date. This file is the primary input for all richness and abundance
        analyses.
      </entityDescription>
      <physical>
        <objectName>TableS1_forAnalysis.csv</objectName>
        <dataFormat>
          <textFormat>
            <numHeaderLines>1</numHeaderLines>
            <recordDelimiter>\n</recordDelimiter>
            <attributeOrientation>column</attributeOrientation>
            <simpleDelimited>
              <fieldDelimiter>,</fieldDelimiter>
            </simpleDelimited>
          </textFormat>
        </dataFormat>
        <distribution>
          <online>
            <url>https://github.com/MariaPaniw/subterranean-invertebrate-trap/blob/main/TableS1_forAnalysis.csv</url>
          </online>
        </distribution>
      </physical>
      <attributeList>
        <attribute>
          <attributeName>Ref</attributeName>
          <attributeLabel>Trap reference code</attributeLabel>
          <attributeDefinition>
            Unique alphanumeric reference code for each trap location and
            layer. Encoded as: [prefix][site (3 chars)][line (L01 or L05)]
            [layer (L01–L03)]. Example: "XABCL01L02" identifies site ABC,
            double-stratified line, layer 2.
          </attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain>
                  <definition>Alphanumeric trap identifier</definition>
                </textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Timestamp</attributeName>
          <attributeLabel>Collection date and time</attributeLabel>
          <attributeDefinition>
            Date and time the trap was collected, in the format
            DD/MM/YY HH:MM.
          </attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <dateTime>
              <formatString>DD/MM/YY HH:MM</formatString>
              <dateTimePrecision>1 minute</dateTimePrecision>
            </dateTime>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Method</attributeName>
          <attributeLabel>Trap design type</attributeLabel>
          <attributeDefinition>
            Trap design used. One of two values: "double-stratified
            subterranean" (L01 line, two layers) or "three-stratified
            subterranean" (L05 line, three layers).
          </attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <enumeratedDomain>
                  <codeDefinition>
                    <code>double-stratified subterranean</code>
                    <definition>Two-layer subterranean trap design (line L01)</definition>
                  </codeDefinition>
                  <codeDefinition>
                    <code>three-stratified subterranean</code>
                    <definition>Three-layer subterranean trap design (line L05)</definition>
                  </codeDefinition>
                </enumeratedDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Class</attributeName>
          <attributeLabel>Taxonomic Class</attributeLabel>
          <attributeDefinition>
            Invertebrate class (e.g., Insecta). Records labelled
            "Unidentified" were excluded from diversity and abundance
            analyses.
          </attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain>
                  <definition>Taxonomic class name</definition>
                </textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Order</attributeName>
          <attributeLabel>Taxonomic Order</attributeLabel>
          <attributeDefinition>Invertebrate order.</attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Taxonomic order name</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Family</attributeName>
          <attributeLabel>Taxonomic Family</attributeLabel>
          <attributeDefinition>Invertebrate family.</attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Taxonomic family name</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Subfamily</attributeName>
          <attributeLabel>Taxonomic Subfamily</attributeLabel>
          <attributeDefinition>Invertebrate subfamily (if identified).</attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Taxonomic subfamily name</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Tribe</attributeName>
          <attributeLabel>Taxonomic Tribe</attributeLabel>
          <attributeDefinition>Invertebrate tribe (if identified).</attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Taxonomic tribe name</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Genera</attributeName>
          <attributeLabel>Taxonomic Genus</attributeLabel>
          <attributeDefinition>Invertebrate genus (if identified).</attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Genus name</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Species</attributeName>
          <attributeLabel>Taxonomic Species</attributeLabel>
          <attributeDefinition>Species epithet (if identified).</attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Species epithet</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Number_caught</attributeName>
          <attributeLabel>Number of individuals caught</attributeLabel>
          <attributeDefinition>
            Count of individuals of the given taxon captured in the trap
            on the given collection event.
          </attributeDefinition>
          <storageType>integer</storageType>
          <measurementScale>
            <ratio>
              <unit><standardUnit>number</standardUnit></unit>
              <numericDomain>
                <numberType>whole</numberType>
                <bounds>
                  <minimum exclusive="false">0</minimum>
                </bounds>
              </numericDomain>
            </ratio>
          </measurementScale>
          <missingValueCode>
            <code>NA</code>
            <codeExplanation>Count not recorded for this event.</codeExplanation>
          </missingValueCode>
        </attribute>
      </attributeList>
    </dataTable>

