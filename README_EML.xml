    <dataTable id="habitat">
      <entityName>subterraneanHabitat_202502.csv</entityName>
      <entityDescription>
        Macrohabitat and site-level covariates for each trap line across
        the 10 study sites. Contains 20 records (10 sites × 2 lines each).
        Used to join land-use category and sand cover to the occurrence data.
      </entityDescription>
      <physical>
        <objectName>subterraneanHabitat_202502.csv</objectName>
        <dataFormat>
          <textFormat>
            <numHeaderLines>1</numHeaderLines>
            <recordDelimiter>\n</recordDelimiter>
            <attributeOrientation>column</attributeOrientation>
            <simpleDelimited>
              <fieldDelimiter>,</fieldDelimiter>
            </simpleDelimited>
          </textFormat>
        </dataFormat>
        <distribution>
          <online>
            <url>https://github.com/MariaPaniw/subterranean-invertebrate-trap/blob/main/subterraneanHabitat_202502.csv</url>
          </online>
        </distribution>
      </physical>
      <attributeList>
        <attribute>
          <attributeName>Site</attributeName>
          <attributeLabel>Full site-line reference</attributeLabel>
          <attributeDefinition>
            Composite key encoding site and trap line, used to derive
            "site" (characters 2–4) and "line" (characters 5–7) via
            substr() in R.
          </attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Alphanumeric site identifier</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>land_use</attributeName>
          <attributeLabel>Land-use / macrohabitat category</attributeLabel>
          <attributeDefinition>
            Categorical macrohabitat descriptor for the site (e.g.,
            degraded / intact, or specific land-use classes). Used as a
            fixed effect in GLMMs.
          </attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Land-use category label</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Sand</attributeName>
          <attributeLabel>Sand cover (%)</attributeLabel>
          <attributeDefinition>
            Proportion or percentage of sand cover at the site-line
            combination. Used as a continuous habitat covariate (hab) in
            statistical models.
          </attributeDefinition>
          <storageType>float</storageType>
          <measurementScale>
            <ratio>
              <unit><standardUnit>dimensionless</standardUnit></unit>
              <numericDomain>
                <numberType>real</numberType>
                <bounds>
                  <minimum exclusive="false">0</minimum>
                  <maximum exclusive="false">100</maximum>
                </bounds>
              </numericDomain>
            </ratio>
          </measurementScale>
        </attribute>
      </attributeList>
    </dataTable>

    <!-- ---------------------------------------------------------- -->
    <!--  3. biomass_data/ folder                                    -->
    <!-- ---------------------------------------------------------- -->
    <dataTable id="biomass">
      <entityName>biomass_data/ (directory of Excel workbooks)</entityName>
      <entityDescription>
        A directory containing multiple Excel (.xlsx) files, one per
        collection event, recording dry biomass and individual counts per
        trap reference. Files are named by collection date
        (DD_MM_YYYY format). The R script reads and concatenates all files
        in this directory. Each workbook contains a single sheet with the
        columns described below.
      </entityDescription>
      <physical>
        <objectName>biomass_data/</objectName>
        <dataFormat>
          <externallyDefinedFormat>
            <formatName>Microsoft Excel Open XML Spreadsheet (.xlsx)</formatName>
          </externallyDefinedFormat>
        </dataFormat>
        <distribution>
          <online>
            <url>https://github.com/MariaPaniw/subterranean-invertebrate-trap/tree/main/biomass_data</url>
          </online>
        </distribution>
      </physical>
      <attributeList>
        <attribute>
          <attributeName>date</attributeName>
          <attributeLabel>Collection date</attributeLabel>
          <attributeDefinition>
            Date the trap was collected (read from column 1 of each workbook).
          </attributeDefinition>
          <storageType>date</storageType>
          <measurementScale>
            <dateTime>
              <formatString>YYYY-MM-DD</formatString>
            </dateTime>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Ref</attributeName>
          <attributeLabel>Trap reference code</attributeLabel>
          <attributeDefinition>
            Same encoding as in TableS1_forAnalysis.csv (see above). 25
            unique references per collection event (10 sites × up to 3
            layers × 2 lines, with the L01×L03 combination absent).
          </attributeDefinition>
          <storageType>string</storageType>
          <measurementScale>
            <nominal>
              <nonNumericDomain>
                <textDomain><definition>Alphanumeric trap identifier</definition></textDomain>
              </nonNumericDomain>
            </nominal>
          </measurementScale>
        </attribute>

        <attribute>
          <attributeName>Weight</attributeName>
          <attributeLabel>Dry biomass (g)</attributeLabel>
          <attributeDefinition>
            Total dry mass of all invertebrates captured in the trap for
            this collection event, in grams.
          </attributeDefinition>
          <storageType>float</storageType>
          <measurementScale>
            <ratio>
              <unit><standardUnit>gram</standardUnit></unit>
              <numericDomain>
                <numberType>real</numberType>
                <bounds>
                  <minimum exclusive="false">0</minimum>
                </bounds>
              </numericDomain>
            </ratio>
          </measurementScale>
          <missingValueCode>
            <code>NA</code>
            <codeExplanation>No invertebrates or weight not recorded.</codeExplanation>
          </missingValueCode>
        </attribute>

        <attribute>
          <attributeName>Number</attributeName>
          <attributeLabel>Total count of individuals</attributeLabel>
          <attributeDefinition>
            Total number of invertebrate individuals in the trap for this
            collection event (all taxa combined).
          </attributeDefinition>
          <storageType>integer</storageType>
          <measurementScale>
            <ratio>
              <unit><standardUnit>number</standardUnit></unit>
              <numericDomain>
                <numberType>whole</numberType>
                <bounds>
                  <minimum exclusive="false">0</minimum>
                </bounds>
              </numericDomain>
            </ratio>
          </measurementScale>
          <missingValueCode>
            <code>NA</code>
            <codeExplanation>Count not recorded for this event.</codeExplanation>
          </missingValueCode>
        </attribute>

        <attribute>
          <attributeName>occ</attributeName>
          <attributeLabel>Sampling occasion (integer)</attributeLabel>
          <attributeDefinition>
            Integer sampling occasion assigned in the R script:
            1 = October–November 2024;
            2 = December 2024;
            3 = January 2025;
            4 = February 2025;
            5 = March 2025.
          </attributeDefinition>
          <storageType>integer</storageType>
          <measurementScale>
            <ordinal>
              <nonNumericDomain>
                <enumeratedDomain>
                  <codeDefinition><code>1</code><definition>Oct–Nov 2024</definition></codeDefinition>
                  <codeDefinition><code>2</code><definition>Dec 2024</definition></codeDefinition>
                  <codeDefinition><code>3</code><definition>Jan 2025</definition></codeDefinition>
